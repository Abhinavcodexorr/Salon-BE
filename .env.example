# Server
PORT=3001
NODE_ENV=development

# Frontend (for CORS)
FRONTEND_URL=http://localhost:4200

# MongoDB
DATABASE_URL=mongodb://localhost:27017/blosm

# Salon booking hours (HH:mm) — fallback when no row exists in SalonAvailability collection.
# After saving via PUT /api/v1/admin/availability, DB values are used.
SALON_AVAILABLE_FROM=09:00
SALON_AVAILABLE_TO=18:00

# JWT
JWT_SECRET=your-jwt-secret

# OTP
# USE_STATIC_OTP=true  -> no SMS, verify with STATIC_OTP (default 123456)
# USE_STATIC_OTP=false -> send real OTP via Notifyre SMS (mobile sign-in only)
USE_STATIC_OTP=true
STATIC_OTP=123456
OTP_EXPIRY_MINUTES=10

# Notifyre SMS (required when USE_STATIC_OTP=false, and for appointment SMS)
NOTIFYRE_API_TOKEN=your-notifyre-api-token
# Optional dedicated sender; leave unset to use Notifyre shared number
# NOTIFYRE_FROM_NUMBER=+61XXXXXXXXX
NOTIFYRE_CAMPAIGN_NAME=Blosm

# Twilio SMS (legacy — no longer used by the app)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+12183094654

# Booking reminder cron (emails 2h before appointment; once per booking)
BOOKING_TIMEZONE=Australia/Adelaide
BOOKING_REMINDER_HOURS_BEFORE=2
BOOKING_REMINDER_CRON_ENABLED=true
BOOKING_REMINDER_CRON_SCHEDULE=*/5 * * * *

# AWS S3 - add real values to .env only (never commit)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-bucket-name

# Gmail API (OAuth2)
# Use values from your client_secret_*.json file
GMAIL_CLIENT_ID=your-google-client-id
GMAIL_CLIENT_SECRET=your-google-client-secret
GMAIL_REFRESH_TOKEN=your-google-refresh-token
GMAIL_SENDER_EMAIL=your-gmail-address@gmail.com
# Optional; defaults to Google OAuth playground URI in code
GMAIL_REDIRECT_URI=https://developers.google.com/oauthplayground
# Optional: pass your frontend callback URI to auth/exchange APIs when needed
