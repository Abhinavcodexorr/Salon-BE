# Server
PORT=3001
NODE_ENV=development

# Frontend (for CORS)
FRONTEND_URL=http://localhost:4200

# MongoDB
DATABASE_URL=mongodb://localhost:27017/blosm
# Or MongoDB Atlas: mongodb+srv://user:pass@cluster.mongodb.net/blosm

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# OTP - use static 123456 (dev default, set true for prod testing)
USE_STATIC_OTP=true

# OTP (optional - for production SMS)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
