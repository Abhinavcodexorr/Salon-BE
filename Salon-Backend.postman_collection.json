{
  "info": {
    "name": "Salon Backend",
    "description": "Admin Panel + Website APIs for Blosm Salon",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4002" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Upload",
      "item": [
        {
          "name": "Upload Image",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "image",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": "{{baseUrl}}/api/v1/upload/image"
          }
        }
      ]
    },
    {
      "name": "Admin Panel",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "const token = res.data?.token;",
                  "if (token) {",
                  "  pm.collectionVariables.set('token', token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"superadmin@admin.com\",\n  \"password\": \"qwerty\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/admin/login"
          }
        },
        {
          "name": "Admin Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/v1/admin/logout"
          }
        },
        {
          "name": "Get Token (Verify OTP)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "const token = res.data?.token || res.token;",
                  "if (token) {",
                  "  pm.collectionVariables.set('token', token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobile\": \"410123456\",\n  \"countryCode\": \"+61\",\n  \"otp\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/verify-otp"
          }
        },
        {
          "name": "Get Services (all)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/services?status=",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "services"],
              "query": [
                { "key": "status", "value": "", "description": "all | active | deactivated" }
              ]
            }
          }
        },
        {
          "name": "Get Services (deactivated only)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/admin/services?status=deactivated"
          }
        },
        {
          "name": "Get Service by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/services/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "services", ":id"],
              "variable": [{ "key": "id", "value": "SERVICE_ID_HERE" }]
            }
          }
        },
        {
          "name": "Get Users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/users?page=1&limit=20&search=",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "users"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "search", "value": "" }
              ]
            }
          }
        },
        {
          "name": "Get Appointments",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/appointments?page=1&limit=20&status=&search=",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "appointments"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "status", "value": "", "description": "pending|confirmed|completed|cancelled" },
                { "key": "search", "value": "" }
              ]
            }
          }
        },
        {
          "name": "Update Appointment Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"confirmed\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/appointments/:id/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "appointments", ":id", "status"],
              "variable": [{ "key": "id", "value": "APPOINTMENT_ID_HERE" }]
            }
          }
        },
        {
          "name": "Create Service",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Hair Styling\",\n  \"description\": \"Indulge in our expert hair styling services tailored to enhance your natural beauty and confidence.\",\n  \"items\": [\"Cut & Styling\", \"Coloring & Highlights\", \"Keratin Treatments\", \"Bridal Hair\"],\n  \"image\": \"https://images.unsplash.com/photo-1562322140-8baeececf3df?w=800&q=85\",\n  \"alt\": \"Hair styling at Blosm\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/admin/services"
          }
        },
        {
          "name": "Update Service",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Hair Styling\",\n  \"description\": \"Updated description.\",\n  \"items\": [\"Cut\", \"Coloring\"],\n  \"image\": \"https://example.com/image.jpg\",\n  \"alt\": \"Updated alt\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/services/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "services", ":id"],
              "variable": [{ "key": "id", "value": "SERVICE_ID_HERE" }]
            }
          }
        },
        {
          "name": "Activate Service",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/services/:id/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "services", ":id", "status"],
              "variable": [{ "key": "id", "value": "SERVICE_ID_HERE" }]
            }
          }
        },
        {
          "name": "Deactivate Service",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isActive\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/services/:id/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "services", ":id", "status"],
              "variable": [{ "key": "id", "value": "SERVICE_ID_HERE" }]
            }
          }
        },
        {
          "name": "Delete Service",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/services/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "services", ":id"],
              "variable": [{ "key": "id", "value": "SERVICE_ID_HERE" }]
            }
          }
        },
        {
          "name": "Seed Services",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"services\": [\n    {\n      \"title\": \"Hair Styling\",\n      \"description\": \"Indulge in our expert hair styling services tailored to enhance your natural beauty and confidence.\",\n      \"items\": [\"Cut & Styling\", \"Coloring & Highlights\", \"Keratin Treatments\", \"Bridal Hair\"],\n      \"image\": \"https://images.unsplash.com/photo-1562322140-8baeececf3df?w=800&q=85\",\n      \"alt\": \"Hair styling at Blosm\"\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/v1/services/seed"
          }
        }
      ]
    },
    {
      "name": "Website (Customer)",
      "item": [
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobile\": \"410123456\",\n  \"countryCode\": \"+61\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/send-otp"
          }
        },
        {
          "name": "Verify OTP & Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "const token = res.data?.token || res.token;",
                  "if (token) {",
                  "  pm.collectionVariables.set('token', token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mobile\": \"410123456\",\n  \"countryCode\": \"+61\",\n  \"otp\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/verify-otp"
          }
        },
        {
          "name": "Get Me (Profile + Wallet)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/v1/users/me"
          }
        },
        {
          "name": "Get Services",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/services"
          }
        },
        {
          "name": "Get Service Titles",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/services/titles"
          }
        },
        {
          "name": "Create Appointment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}", "disabled": true }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"mobile\": \"410123456\",\n  \"countryCode\": \"+61\",\n  \"service\": \"Hair Cutting\",\n  \"date\": \"2025-03-25\",\n  \"time\": \"10:00\",\n  \"notes\": \"First visit\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/appointments"
          }
        },
        {
          "name": "Get My Appointments",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/v1/appointments/my"
          }
        }
      ]
    },
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    }
  ]
}
